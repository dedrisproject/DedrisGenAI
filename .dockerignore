# Build context = repo root. Keep it lean: exclude VCS, provisioned runtimes, and
# all model weights (downloaded at runtime into the data volume). Small support
# files (config/tokenizer json, style sample jpgs) are NOT excluded.
.git
.github
.gitignore
.gitattributes

# Provisioned portable runtimes (PHP + Python venv with torch) — GBs, never needed in the image.
runtimes/

# Model weights at any depth (the image stays small; weights download at runtime).
**/*.ckpt
**/*.safetensors
**/*.pth
**/*.pt
**/*.bin
**/*.onnx
**/*.fooocus.patch
**/*.dedris.patch

# Generated / local artifacts
**/outputs/
**/__pycache__/
**/*.pyc
engine/config.txt
engine/user_path_config*.txt
webui/runtime/
webui/*.log

# macOS / editor noise
**/._*
.DS_Store
**/.DS_Store
.vscode
.idea
